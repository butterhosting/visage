{
  "name": "visage",
  "version": "0.0.0-snapshot",
  "commit": "0000000000000000000000000000000000000000",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "scripts": {
    "drizzle": "sh -c ': \"${1:?Please pass a migration name}\"; bunx drizzle-kit generate --name=$1 --custom' _",
    "install:browsers": "playwright install chromium --with-deps",
    "dev": "docker compose up",
    "tracker:build": "bun build --minify --outfile=opt/visage/tracker/vis.js src/tracker/vis.ts",
    "tracker:watch": "bun tracker:build --watch",
    "tc": "bunx tsc --noEmit",
    "lint": "bunx tsc --noEmit -p tsconfig.lint.json && bunx knip-bun",
    "test:unit": "bun test",
    "start:dev": "concurrently --kill-others \"bun tracker:watch\" \"bun --env-file=.env.dev --env-file=.env --hot src/index.ts\"",
    "start:e2e": "bun tracker:build && bun --env-file=.env.e2e src/index.ts",
    "start:prod": "bun tracker:build && bun --env-file=.env.prod src/index.ts",
    "e2e": "playwright test --ui",
    "e2e:headless": "playwright test --max-failures 1 --reporter github"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@maxmind/geoip2-node": "^6.3.4",
    "bowser": "^2.14.1",
    "bun-plugin-tailwind": "^0.1.2",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "drizzle-orm": "^0.45.1",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7.13.1",
    "recharts": "^3.8.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "yesttp": "^2.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bun": "1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "knip": "^6.4.0",
    "typescript": "^5.9.3"
  }
}
